<?xml version="1.0" encoding="utf-8" standalone="yes"?><rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom"><channel><title>Postcard Layout on Monochrome</title><link>https://kaiiiz.github.io/hugo-theme-monochrome/layouts/postcard/</link><description>Recent content in Postcard Layout on Monochrome</description><generator>Hugo -- gohugo.io</generator><language>en</language><managingEditor>kaiiiz</managingEditor><webMaster>kaiiiz</webMaster><atom:link href="https://kaiiiz.github.io/hugo-theme-monochrome/layouts/postcard/index.xml" rel="self" type="application/rss+xml"/><item><title>Postcard Layout Document</title><link>https://kaiiiz.github.io/hugo-theme-monochrome/layouts/postcard/docs/</link><pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate><author>kaiiiz</author><guid>https://kaiiiz.github.io/hugo-theme-monochrome/layouts/postcard/docs/</guid><description>&lt;p&gt;Postcard layout show summary of regular posts, it&amp;rsquo;s useful for creating home page.&lt;/p&gt;
&lt;blockquote&gt;
&lt;p&gt;This layout can only be used on list layout.&lt;/p&gt;
&lt;/blockquote&gt;
&lt;h2 class="header-anchor-wrapper"&gt;Configuration
&lt;a href="#configuration" class="header-anchor-link"&gt;
&lt;svg
xmlns="http://www.w3.org/2000/svg"
width="1rem" height="1rem" viewBox="0 0 24 24" fill="none"
stroke="currentColor" stroke-width="2" stroke-linecap="round"
stroke-linejoin="round"&gt;
&lt;line x1="4" y1="9" x2="20" y2="9"&gt;&lt;/line&gt;&lt;line x1="4" y1="15" x2="20" y2="15"&gt;&lt;/line&gt;&lt;line x1="10" y1="3" x2="8" y2="21"&gt;&lt;/line&gt;&lt;line x1="16" y1="3" x2="14" y2="21"&gt;&lt;/line&gt;
&lt;/svg&gt;
&lt;/a&gt;
&lt;/h2&gt;
&lt;pre&gt;&lt;code class="language-yaml"&gt;---
type: 'postcard'
---
&lt;/code&gt;&lt;/pre&gt;
&lt;blockquote&gt;
&lt;p&gt;Specify &lt;code&gt;type&lt;/code&gt; in front-matter will change the template lookup order.&lt;/p&gt;
&lt;/blockquote&gt;</description></item></channel></rss>